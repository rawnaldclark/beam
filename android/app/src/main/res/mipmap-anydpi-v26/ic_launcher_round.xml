<?xml version="1.0" encoding="utf-8"?>
<!--
    Round adaptive icon variant for launchers that apply a circular mask.
    Shares the same background/foreground drawables as ic_launcher.xml.
    Replace with a dedicated round foreground vector asset if the design
    requires different safe-zone padding for the circular crop.
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/ic_launcher_background"/>
    <foreground android:drawable="@color/ic_launcher_foreground"/>
</adaptive-icon>
