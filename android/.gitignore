# Android / IntelliJ generated files — not committed to source control.

# IntelliJ / Android Studio module files (regenerated on project import)
*.iml

# Gradle build cache and daemon files
.gradle

# Local SDK/NDK path configuration — machine-specific, never shared
/local.properties

# IDE project settings — contain machine-specific paths and personal preferences
.idea

# All build outputs
build/

# Profiling captures from Android Studio
captures

# Native build directories (CMake / NDK, not used by this project but guard against
# them appearing if someone adds C++ sources)
.externalNativeBuild
.cxx

# Keystore files — NEVER commit signing keys
*.jks
*.keystore

# Generated Room schema JSON — COMMIT this: it's used for migration validation
# Uncomment the line below ONLY if you explicitly don't want schema tracking:
# app/schemas/

# Gradle wrapper JAR and scripts — generated by `gradle wrapper`, not committed
# because the binary JAR (~58 KB) belongs in .gitignore per Android best practices.
# To bootstrap a fresh checkout: `gradle wrapper --gradle-version 8.6`
gradle/wrapper/gradle-wrapper.jar
gradlew
gradlew.bat
